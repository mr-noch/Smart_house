<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SmartHouseUI.GuiLogic.RoomDevicesPanel">

    <Border Background="#2d2d30" Width="360" Padding="18" CornerRadius="16">
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*, Auto">
                <TextBlock Text="Керування пристроями" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <Button Content="✕" Click="ClosePanel" Background="#444" Foreground="White" Width="30" Height="30" HorizontalAlignment="Right"/>
            </Grid>

            <TextBlock Text="Кімната:" Foreground="Gray" FontSize="12"/>
            <TextBlock x:Name="RoomNameText" Foreground="White" FontSize="16" FontWeight="Bold"/>

            <Border Background="#1f1f21" CornerRadius="10" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Додати пристрій" Foreground="White" FontWeight="SemiBold"/>
                    <TextBox x:Name="DeviceNameInput" Watermark="Назва пристрою..."/>
                    <ComboBox x:Name="DeviceTypeComboBox" HorizontalAlignment="Stretch"/>
                    <Button Content="Додати пристрій" Click="AddDevice" HorizontalAlignment="Stretch" Background="#2d89ef" Foreground="White"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Список пристроїв" Foreground="White" FontWeight="Bold"/>
            <ScrollViewer Height="240">
                <StackPanel x:Name="DevicesListPanel" Spacing="10"/>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
